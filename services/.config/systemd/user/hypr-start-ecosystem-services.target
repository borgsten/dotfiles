[Unit]
Description=Extra ecosystem services for Hyprland session
BindsTo=wayland-session@start\x2dhyprland.target
After=wayland-session@start\x2dhyprland.target
Wants=elephant.service walker.service hypridle.service hyprpaper.service swaync.service swayosd.service hyprpolkitagent.service waybar.service

[Install]
WantedBy=wayland-session@start\x2dhyprland.target
